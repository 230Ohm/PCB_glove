  (text "STM32N6570-DK FOUR-CONNECTOR DIGITAL INTERFACE - DRAFT DEVELOPMENT HARDWARE" (at 15.24 15.24 0)
    (effects (font (size 2 2) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000176)
  )
  (text "DK POSITIVE POWER PINS MUST NOT CONNECT TO PCB_GLOVE" (at 15.24 25.4 0)
    (effects (font (size 1.8 1.8) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000177)
  )
  (text "PCB_GLOVE POWERED THROUGH J9 EXTERNAL INPUT ONLY" (at 15.24 33.02 0)
    (effects (font (size 1.8 1.8) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000178)
  )
  (text "CN8-2 IOREF, CN8-4 3V3, CN8-5 5V, CN8-8 VIN: EXPLICIT NO-CONNECT. CN8-1 NC and CN8-3 RESET also DNC." (at 15.24 40.64 0)
    (effects (font (size 1.27 1.27) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000179)
  )
  (text "CN7 DNC: pins 1,2,3,5,6. CN11 DNC: pins 1,2. CN12 DNC: pins 8 AREF, 9 SDA, 10 SCL." (at 15.24 48.26 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000180)
  )
  (text "J14 SPI cavities: 1 SCK, 2 GND, 3 MISO, 4 GND, 5 MOSI, 6 DNC / NO TERMINAL." (at 15.24 195.58 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000181)
  )
  (text "J15 CS cavities: 1 THUMB, 2 GND, 3 INDEX, 4 MIDDLE, 5 RING, 6 PINKY." (at 15.24 203.2 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000182)
  )
  (text "J16 INT cavities: 1 THUMB, 2 GND, 3 INDEX, 4 MIDDLE, 5 RING, 6 PINKY." (at 15.24 210.82 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000183)
  )
  (text "CS PULL-UPS KEEP ALL IMUS DESELECTED WHILE DK IS OFF, RESETTING, BOOTING, HALTED, OR DISCONNECTED" (at 15.24 220.98 0)
    (effects (font (size 1.5 1.5) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000184)
  )
  (text "R18-R22 = 10k to +3V3_IMU on glove side. PROVISIONAL - PHYSICAL RESET/BACKFEED VALIDATION REQUIRED." (at 15.24 228.6 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000185)
  )
  (text "SPI5 initial firmware: MODE 3, IDLE HIGH, SOFTWARE NSS, 100 kHz-1 MHz. Final speed requires signal-integrity validation." (at 15.24 236.22 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000186)
  )
  (text "ISM330DHCX INT1: active-high push-pull. MCU inputs: no internal pull. EXTI: thumb 10, index 5, middle 9, ring 0, pinky 11." (at 15.24 243.84 0)
    (effects (font (size 1.27 1.27)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000187)
  )
  (text "DEFERRED PHYSICAL VALIDATION - NOT MEASURED" (at 15.24 251.46 0)
    (effects (font (size 1.8 1.8) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000188)
  )
  (text "NOT PHYSICALLY QUALIFIED / NOT WEARABLE QUALIFIED / NOT FOR FABRICATION" (at 15.24 259.08 0)
    (effects (font (size 1.8 1.8) (thickness 0.4)) (justify left bottom))
    (uuid d2a5c6e7-9b10-4c3d-8e4f-000000000189)
